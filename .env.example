# Local development defaults for docker-compose.
# Copy this file to .env before running `docker compose up`:
#   cp .env.example .env
#
# .env is gitignored — edit freely. Never commit real secrets here.

# --- MySQL container ---
MYSQL_DATABASE=customer_hub
MYSQL_USER=customer_hub
MYSQL_PASSWORD=customer_hub_dev_pw
MYSQL_ROOT_PASSWORD=root_dev_pw

# --- App: JWT signing (HS256, ≥ 32 characters) ---
JWT_SECRET=local-development-only-jwt-secret-change-me-32chars-min
JWT_ISSUER=customer-support-hub
JWT_TTL_MINUTES=60

# --- App: admin bootstrap seeder ---
# Runs once on first boot when SEED_ADMIN_ENABLED=true and no users exist.
SEED_ADMIN_ENABLED=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin_dev_pw
SEED_ADMIN_EMAIL=admin@surense.local
SEED_ADMIN_FULL_NAME=System Administrator
